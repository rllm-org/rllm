{
  "version": 1,
  "agents": {
    "react": {
      "module": "rllm.harnesses.react",
      "function": "ReActHarness",
      "description": "One-shot LLM call. Default for data tasks (math, MCQ, QA)."
    },
    "bash": {
      "module": "rllm.harnesses.bash",
      "function": "BashHarness",
      "description": "Multi-turn ReAct bash loop inside a sandbox."
    },
    "opencode": {
      "module": "rllm.harnesses.opencode",
      "function": "OpenCodeHarness",
      "description": "Run the opencode-ai CLI inside the sandbox."
    },
    "mini-swe-agent": {
      "module": "rllm.harnesses.mini_swe_agent",
      "function": "MiniSweAgentHarness",
      "description": "Run mini-swe-agent inside the sandbox."
    }
  }
}
